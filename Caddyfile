# MV-Companion OS — Caddy reverse proxy
# Replace yourdomain.com with your actual domain
# Caddy auto-provisions Let's Encrypt SSL

yourdomain.com {
  # Next.js app
  reverse_proxy app:3000

  # Supabase API (optional direct access)
  handle /supabase/* {
    uri strip_prefix /supabase
    reverse_proxy kong:8000
  }

  # Security headers
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy strict-origin-when-cross-origin
    -Server
  }
}

# Local dev — no SSL needed
# Replace above block with this for local testing:
# :80 {
#   reverse_proxy app:3000
# }
