# MV-Companion OS — Environment Variables
# Copy to .env and fill in all values before running docker compose up
# NEVER commit .env to git — it is in .gitignore

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=            # 32-char random — DB superuser password
POSTGRES_DB=postgres
POSTGRES_HOST=db

# ── Supabase internal config ────────────────────────────────────────────────
JWT_SECRET=                   # 32-char random — shared by auth + rest
ANON_KEY=                     # Derived from JWT_SECRET (supabase-jwt tool)
SERVICE_ROLE_KEY=             # Derived from JWT_SECRET (supabase-jwt tool)
SECRET_KEY_BASE=              # 64-char random — used by Realtime (Elixir)
SITE_URL=https://app.yourdomain.com
API_EXTERNAL_URL=https://api.yourdomain.com
ADDITIONAL_REDIRECT_URLS=

# ── Supabase Auth / SMTP ────────────────────────────────────────────────────
ENABLE_EMAIL_AUTOCONFIRM=true
GOTRUE_SMTP_HOST=             # SMTP server for magic links / invites
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_SENDER_NAME=MV-Companion OS

# ── Next.js App ─────────────────────────────────────────────────────────────
# Browser-side — must be the public Caddy-proxied URL (not internal kong)
NEXT_PUBLIC_SUPABASE_URL=https://api.yourdomain.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Same value as ANON_KEY
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
# Server-side (internal Docker hostname — do not prefix with NEXT_PUBLIC_)
# SUPABASE_URL is hardcoded as http://kong:8000 in docker-compose.yml
# SERVICE_ROLE_KEY is used from the variable above

# ── AI Providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── OpenClaw ─────────────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=       # Auth token for OpenClaw gateway API
# OPENCLAW_SUPABASE_URL and OPENCLAW_SUPABASE_KEY are set in docker-compose.yml
DISCORD_BOT_TOKEN=
MSTEAMS_APP_ID=
MSTEAMS_APP_PASSWORD=
MSTEAMS_TENANT_ID=

# ── Logflare (analytics) ────────────────────────────────────────────────────
LOGFLARE_API_KEY=             # Any random string for single-tenant mode

# ── Caddy — Supabase Studio IP allowlist ────────────────────────────────────
STUDIO_ALLOWED_IP=            # Your office/home IP — studio.yourdomain.com is blocked to all others
